{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node@3.2.17"
    },
    "api/tailwindcss.js": {
      "runtime": "@vercel/node@3.2.17"
    }
  },
  "routes": [
    {
      "src": "/api/tailwindcss",
      "dest": "/api/tailwindcss.js"
    },
    {
      "src": "/api/create",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
